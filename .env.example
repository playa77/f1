# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Brave Search API
BRAVE_SEARCH_API_KEY=BSA-your-key-here

# OpenRouter Model Configuration
OPENROUTER_STRONG_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_FAST_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b

# Application Configuration
F1_SEASON=2026
APP_HOST=127.0.0.1
APP_PORT=8080
SQLITE_PATH=data/f1_analyzer.sqlite
REPORTS_DIR=exports
PAGE_FETCH_ENABLED=true

# Timeouts (seconds)
SEARCH_TIMEOUT=30
MODEL_TASK_TIMEOUT=120
SIMULATION_TIMEOUT=300
REPORT_TIMEOUT=60

# Daily Job Schedule (hour:minute in 24h format, in daily_job_timezone timezone)
DAILY_JOB_SCHEDULE=03:00
DAILY_JOB_TIMEZONE=Europe/Berlin

# Data retention (days before stale uncited sources are pruned)
DATA_RETENTION_DAYS=90

# Embedding Validation
MIN_EMBEDDING_DIMENSION=1536
